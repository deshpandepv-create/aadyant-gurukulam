{
  "appId": "org.deshpandeeducation.aadyant",
  "appName": "Aadyant Gurukulam",
  "webDir": "dist",
  "server": {
    "url": "https://school.deshpandeeducationfoundation.org",
    "cleartext": false,
    "androidScheme": "https"
  },
  "android": {
    "backgroundColor": "#1A2340",
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#1A2340",
      "androidSplashResourceName": "splash",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "dark",
      "backgroundColor": "#1A2340"
    },
    "Keyboard": {
      "resize": "body",
      "style": "dark",
      "resizeOnFullScreen": true
    }
  }
}
